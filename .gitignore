CLAUDE.md

# Local Claude Code permissions (contains allowed domains)
.claude/settings.local.json

# Real agents (business-specific) — agents/ has the sanitized public versions
.claude/agents/

# Environment — keys never go to git
.env
.env.*

# macOS
.DS_Store

# Editor
.vscode/
*.swp
